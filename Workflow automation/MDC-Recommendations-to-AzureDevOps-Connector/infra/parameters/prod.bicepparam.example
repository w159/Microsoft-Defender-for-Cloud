// Copy to prod.bicepparam and fill in your values before deploying.
//   cp prod.bicepparam.example prod.bicepparam
using '../main.bicep'

param env = 'prod'
param location = 'eastus'
param deployKeyVault = false

param adoOrgUrl = 'https://dev.azure.com/<your-ado-org>'
param adoProject = '<your-ado-project>'

// Create a dedicated prod Entra app registration for the Function's Easy Auth audience.
param functionApiClientId = '<app-registration-client-id>'

param mdcWriteBackEnabled = false
param mdcAssignmentOwnerDomain = 'ado.local'
